{
  "name": "@repomon/desktop",
  "version": "0.5.0",
  "description": "Repomon mission control desktop app",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bindings:generate": "TS_RS_EXPORT_DIR=../../apps/desktop/src/bindings cargo test -p repomon-core --features ts export_bindings -- --nocapture",
    "bindings:check": "bun run bindings:generate && git diff --exit-code -- src/bindings",
    "serve": "vite preview",
    "sidecar:prepare": "bun scripts/prepare-sidecar.ts",
    "tauri": "tauri",
    "tauri:build": "bun run sidecar:prepare && tauri build --config src-tauri/tauri.release.conf.json"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@tauri-apps/api": "~2.9.0",
    "@tauri-apps/plugin-notification": "~2.3.0",
    "@tauri-apps/plugin-process": "~2.3.0",
    "@tauri-apps/plugin-updater": "~2.9.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "solid-js": "^1.9.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "~2.9.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^24.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.2.4"
  }
}
